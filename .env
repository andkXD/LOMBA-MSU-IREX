# ─────────────────────────────────────────────────────────────
# NERIC Backend — Environment Configuration
# Copy file ini jadi .env dan isi sesuai setup kamu
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── MQTT Broker (Mosquitto) ──────────────────────────────────
# Saat testing lokal: gunakan localhost
# Saat pakai ESP32: ganti dengan IP laptop kamu di WiFi
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT Topics
MQTT_TOPIC_SENSOR=neric/sensor/#
MQTT_TOPIC_SIGNAL=neric/signal/

# ── InfluxDB 3 OSS (Local) ───────────────────────────────────
# Jalankan InfluxDB 3 OSS lokal:
#   ./influxdb3 serve --object-store file --data-dir ./influxdb3_data
#
# CATATAN PENTING untuk InfluxDB 3 OSS:
#   - URL selalu localhost:8181 (port default v3)
#   - INFLUXDB_ORG tidak dipakai di v3 (dihapus)
#   - INFLUXDB_TOKEN: generate dengan perintah di bawah
#     ./influxdb3 create token --admin
#   - INFLUXDB_DATABASE menggantikan INFLUXDB_BUCKET di v3
INFLUXDB_URL=http://localhost:8181
INFLUXDB_TOKEN=apiv3_HpXfGojkJjYyQGVELm7o7-sPRLQdbNkbuu1yHautRZAMViUmYaVl9snC9muw7JOXv2uEzDiniydYyMDol7j5Eg
INFLUXDB_DATABASE=neric-data

# ── NERIC Config ─────────────────────────────────────────────
MAX_VEHICLES=20
GREEN_MIN=10
GREEN_MAX=60
EMERGENCY_RATIO=0.85