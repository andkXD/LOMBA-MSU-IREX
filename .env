# ─────────────────────────────────────────────────────────────
# NERIC Backend — Environment Configuration
# Copy file ini jadi .env dan isi sesuai setup kamu
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── MQTT Broker (Mosquitto) ──────────────────────────────────
# Saat testing lokal: gunakan localhost
# Saat pakai ESP32: ganti dengan IP laptop kamu di WiFi
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT Topics
MQTT_TOPIC_SENSOR=neric/sensor/#
MQTT_TOPIC_SIGNAL=neric/signal/

# ── InfluxDB ─────────────────────────────────────────────────
# Jalankan InfluxDB lokal: docker run -p 8086:8086 influxdb:2
# Atau pakai InfluxDB Cloud gratis: https://cloud2.influxdata.com
INFLUXDB_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUXDB_TOKEN=VjEY0L3hsUFpMzxEgaEcSQ6p2rE7a8aHyup1nl5zXSt8VkxyqdVNJPKP3JTdyn7_8nhSGmqe7e2DrzoleR_ZlQ==

INFLUXDB_ORG=Teazzi
INFLUXDB_BUCKET=neric-data

# ── NERIC Config ─────────────────────────────────────────────
MAX_VEHICLES=20
GREEN_MIN=10
GREEN_MAX=60
EMERGENCY_RATIO=0.85
