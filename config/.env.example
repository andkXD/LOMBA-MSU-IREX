# ── NERIC Backend Configuration ──
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai.

# InfluxDB 3 OSS Configuration
# URL default untuk instalasi lokal adalah http://localhost:8181
INFLUXDB_URL=http://localhost:8181
# Token admin yang digenerate melalui: ./influxdb3.exe create token --admin
INFLUXDB_TOKEN=your_local_admin_token_here
INFLUXDB_DATABASE=neric-data

# MQTT Broker Configuration
# Pastikan Mosquitto sudah terinstal dan berjalan sebagai service
MQTT_BROKER=localhost
MQTT_PORT=1883

# NERIC System Config
# Skala kendaraan maksimal (default: 20)
MAX_VEHICLES=20
EMERGENCY_RATIO=0.85